### src/kinematics/robot.js
Robot model configuration. Exports a factory function and constants.

```
export const DEFAULT_NUM_JOINTS = 7
export const MIN_JOINTS = 4
export const MAX_JOINTS = 10
export const LINK_LENGTH = 0.4

export function createRobotState(numJoints)
  // Returns:
  // {
  //   numJoints: number,
  //   angles: Float64Array(numJoints),  -- initialized with small random perturbations [-0.15, 0.15]
  //   linkLength: 0.4,
  //   jointAxes: array of 'z' or 'y' strings -- even indices = 'z', odd indices = 'y'
  //   localLinkVector: [0, 0.4, 0]  -- "up" in local frame
  // }
  //
  // The random perturbation in initial angles breaks the straight-line singularity.
  // Without it, the Jacobian is rank-deficient at zero config because all joints
  // are collinear and cross products are zero.

export function resetAngles(state)
  // Reset all angles to small random perturbations (not zero)
```

