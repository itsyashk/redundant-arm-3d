### src/kinematics/fk.js
Forward kinematics. The most important function in the app.

```
import { mat3_multiply, mat3_vec_multiply, mat3_identity } from '../math/matrix.js'
import { add } from '../math/vector.js'
import { Rz, Ry } from '../math/rotations.js'

export function forwardKinematics(state)
  // Input: state from robot.js (needs .angles, .numJoints, .linkLength, .jointAxes)
  //
  // Output: {
  //   positions: Array of (numJoints + 1) 3D vectors -- [base, joint1, ..., jointN, endEffector]
  //             (positions[0] = [0,0,0] = base, positions[numJoints] = end effector)
  //   axes: Array of numJoints 3D vectors -- world-frame rotation axis of each joint
  // }
  //
  // Algorithm:
  //   R_cumulative = I_3x3
  //   current_pos = [0, 0, 0]
  //   positions = [current_pos]
  //   axes = []
  //
  //   for i = 0 to numJoints - 1:
  //     // Local axis
  //     if jointAxes[i] == 'z': local_axis = [0, 0, 1]
  //     else: local_axis = [0, 1, 0]
  //
  //     // World axis (for Jacobian)
  //     world_axis = mat3_vec_multiply(R_cumulative, local_axis)
  //     axes.push(world_axis)
  //
  //     // Joint rotation matrix
  //     if jointAxes[i] == 'z': R_joint = Rz(angles[i])
  //     else: R_joint = Ry(angles[i])
  //
  //     // Accumulate rotation
  //     R_cumulative = mat3_multiply(R_cumulative, R_joint)
  //
  //     // Link vector in world frame
  //     world_link = mat3_vec_multiply(R_cumulative, [0, linkLength, 0])
  //
  //     // Next position
  //     current_pos = add(current_pos, world_link)
  //     positions.push(current_pos)
  //
  //   return { positions, axes }
  //
  // VERIFICATION:
  // At near-zero angles, positions should form a near-vertical column
  // positions[numJoints] should be approximately [0, numJoints * linkLength, 0]
```

