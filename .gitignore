## FILE-BY-FILE SPECIFICATION

---

### src/math/vector.js
Exports pure functions. No classes. All vectors are length-3 arrays [x, y, z].

```
export function dot(a, b)
  return a[0]*b[0] + a[1]*b[1] + a[2]*b[2]

export function cross(a, b)
  return [
    a[1]*b[2] - a[2]*b[1],
    a[2]*b[0] - a[0]*b[2],
    a[0]*b[1] - a[1]*b[0]
  ]

export function add(a, b)
  return [a[0]+b[0], a[1]+b[1], a[2]+b[2]]

export function sub(a, b)
  return [a[0]-b[0], a[1]-b[1], a[2]-b[2]]

export function scale(a, s)
  return [a[0]*s, a[1]*s, a[2]*s]

export function norm(a)
  return Math.sqrt(dot(a, a))

export function normalize(a)
  const n = norm(a)
  if (n < 1e-10) return [0, 0, 0]
  return scale(a, 1/n)

export function distance(a, b)
  return norm(sub(a, b))

export function clampScalar(val, min, max)
  return Math.max(min, Math.min(max, val))
```

---

### src/math/matrix.js
All matrices stored as flat Float64Array in ROW-MAJOR order. Element (i,j) of an MxN matrix is at index i*N + j.

Exports:

```
// --- Creation ---

export function mat3_identity()
  return new Float64Array([1,0,0, 0,1,0, 0,0,1])

export function matN_identity(n)
  // returns NxN identity as Float64Array of length n*n

export function mat_zeros(rows, cols)
  return new Float64Array(rows * cols)


// --- 3x3 Operations ---

export function mat3_multiply(A, B)
  // standard 3x3 multiply, returns new Float64Array(9)
  // C[i*3+j] = sum_k A[i*3+k] * B[k*3+j]

export function mat3_transpose(A)
  // swap (i,j) and (j,i), returns new Float64Array(9)

export function mat3_vec_multiply(A, v)
  // A is 3x3 flat array, v is [x,y,z]
  // returns [x', y', z']

export function mat3_determinant(A)
  // A[0]*(A[4]*A[8]-A[5]*A[7]) - A[1]*(A[3]*A[8]-A[5]*A[6]) + A[2]*(A[3]*A[7]-A[4]*A[6])

export function mat3_inverse(A)
  // cofactor method
  // compute determinant, if abs(det) < 1e-10 return identity
  // compute adjugate (transposed cofactor matrix)
  // multiply each element by 1/det
  // return new Float64Array(9)

export function mat3_add_scaled_identity(A, s)
  // returns A + s*I  (for damping: A + lambda^2 * I)
  // modifies diagonal: result[0] += s, result[4] += s, result[8] += s


// --- General MxN Operations ---

export function matMN_multiply(A, B, rowsA, colsA, colsB)
  // A is rowsA x colsA, B is colsA x colsB
  // returns Float64Array(rowsA * colsB)
  // C[i*colsB + j] = sum_k A[i*colsA + k] * B[k*colsB + j]

export function matMN_transpose(A, rows, cols)
  // returns Float64Array(cols * rows)
  // result[j*rows + i] = A[i*cols + j]

export function matMN_vec_multiply(A, v, rows, cols)
  // A is rows x cols, v is length-cols array
  // returns length-rows array
  // result[i] = sum_j A[i*cols + j] * v[j]

export function matMN_subtract(A, B, len)
  // element-wise subtraction, returns new Float64Array(len)
```

CRITICAL: Every function that creates a new array should use Float64Array for performance. But the return from mat3_vec_multiply and matMN_vec_multiply should be regular Arrays (length 3 or N) since they represent vectors used with the vector.js functions.

---

### src/math/rotations.js
Exports functions that return 3x3 rotation matrices as Float64Array(9) in row-major order.

```
export function Rz(theta)
  const c = Math.cos(theta), s = Math.sin(theta)
  return new Float64Array([c, -s, 0, s, c, 0, 0, 0, 1])

export function Ry(theta)
  const c = Math.cos(theta), s = Math.sin(theta)
  return new Float64Array([c, 0, s, 0, 1, 0, -s, 0, c])

export function Rx(theta)
  const c = Math.cos(theta), s = Math.sin(theta)
  return new Float64Array([1, 0, 0, 0, c, -s, 0, s, c])

export function rotationAboutAxis(axis, theta)
  // axis is 'x', 'y', or 'z'
  // dispatches to Rx, Ry, or Rz
```

---

### src/math/eigen.js
3x3 symmetric matrix eigendecomposition for the manipulability ellipsoid.

```
export function eigendecompose3x3_symmetric(A)
  // A is a 3x3 symmetric matrix (Float64Array(9))
  // Returns { values: [l1, l2, l3], vectors: [v1, v2, v3] }
  // where l1 >= l2 >= l3 and v_i are unit eigenvectors
  //
  // Use the Jacobi eigenvalue algorithm:
  // 1. Copy A to working matrix
  // 2. Repeatedly find the largest off-diagonal element
  // 3. Apply Givens rotation to zero it out
  // 4. Accumulate rotations to get eigenvectors
  // 5. Converge when off-diagonal elements < 1e-10
  // 6. Diagonal elements are eigenvalues
  //
  // Max iterations: 50 (always converges for 3x3 in practice)
  //
  // IMPORTANT: Clamp eigenvalues to max(val, 0) before returning
  // (numerical noise can produce tiny negatives for near-singular matrices)
  //
  // Sort eigenvalues descending, reorder eigenvectors to match
```

