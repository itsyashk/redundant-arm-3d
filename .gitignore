### src/scene/robotMeshes.js
Manages all Three.js meshes for the robot arm. Must handle rebuilding when joint count changes.

```
import * as THREE from 'three'

export function createRobotMeshes(scene, numJoints)
  // Creates and returns:
  // {
  //   linkMeshes: Array of Mesh (numJoints cylinders)
  //   jointMeshes: Array of Mesh (numJoints spheres)
  //   eeMesh: Mesh (end effector sphere)
  //   eeLight: PointLight (attached to eeMesh)
  //   baseMesh: Mesh (base disc)
  //   dispose(): function that removes all meshes from scene and disposes geometry/material
  // }
  //
  // Link meshes:
  //   CylinderGeometry(0.03, 0.03, 1, 8) -- unit height, scaled per frame
  //   MeshStandardMaterial, color per link: HSL hue = i/numJoints * 0.8, sat 0.7, lightness 0.55
  //   castShadow = true
  //
  // Joint meshes:
  //   SphereGeometry(0.06, 16, 12)
  //   MeshStandardMaterial color 0xe0e0e0, emissive 0x222233, roughness 0.3, metalness 0.6
  //   castShadow = true
  //
  // End effector:
  //   SphereGeometry(0.1, 24, 18)
  //   MeshStandardMaterial color 0x00ffcc, emissive 0x00aa88, emissiveIntensity 0.5, roughness 0.2, metalness 0.8
  //   Attach PointLight(0x00ffcc, 1.0, 3) as child
  //
  // Base:
  //   CylinderGeometry(0.15, 0.18, 0.08, 24)
  //   MeshStandardMaterial color 0x444466, roughness 0.5, metalness 0.7
  //   position.y = 0.04
  //
  // dispose() MUST:
  //   Remove every mesh from scene
  //   Call geometry.dispose() and material.dispose() on every mesh
  //   Remove eeLight from eeMesh and dispose
  //   This prevents GPU memory leaks when rebuilding the arm

export function updateRobotMeshes(meshes, positions)
  // positions: array of 3D vectors from FK (length numJoints + 1)
  //
  // Update joint meshes:
  //   for i in 0..numJoints-1:
  //     jointMeshes[i].position.set(...positions[i])
  //
  // Update end effector:
  //   eeMesh.position.set(...positions[numJoints])
  //
  // Update link meshes (cylinder between positions[i] and positions[i+1]):
  //   for i in 0..numJoints-1:
  //     p1 = new THREE.Vector3(...positions[i])
  //     p2 = new THREE.Vector3(...positions[i+1])
  //     mid = p1.clone().add(p2).multiplyScalar(0.5)
  //     dir = p2.clone().sub(p1)
  //     len = dir.length()
  //
  //     linkMeshes[i].position.copy(mid)
  //     linkMeshes[i].scale.set(1, len, 1)
  //
  //     // Orient cylinder Y-axis along link direction
  //     const up = new THREE.Vector3(0, 1, 0)
  //     const quat = new THREE.Quaternion()
  //     if (len > 1e-6) {
  //       quat.setFromUnitVectors(up, dir.normalize())
  //     }
  //     linkMeshes[i].quaternion.copy(quat)
```

