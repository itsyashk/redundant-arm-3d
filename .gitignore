### src/kinematics/jacobian.js
Geometric Jacobian computation.

```
import { cross, sub } from '../math/vector.js'

export function computeJacobian(positions, axes, numJoints)
  // Returns Float64Array(3 * numJoints) -- 3xN matrix in row-major
  //
  // For each joint i:
  //   r = sub(positions[numJoints], positions[i])  // vector from joint to end effector
  //   col = cross(axes[i], r)
  //
  //   J[0 * numJoints + i] = col[0]   // row 0 (x)
  //   J[1 * numJoints + i] = col[1]   // row 1 (y)
  //   J[2 * numJoints + i] = col[2]   // row 2 (z)
  //
  // This is the position-only geometric Jacobian for revolute joints.
  // Each column is the linear velocity contribution of joint i to the end effector.

export function computeManipulability(J, numJoints)
  // Compute JJt (3x3) then return sqrt(max(det(JJt), 0))
  // Use mat3_determinant from matrix.js
```

