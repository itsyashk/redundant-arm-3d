### src/kinematics/ik.js
Inverse kinematics solver.

```
import { forwardKinematics } from './fk.js'
import { computeJacobian, computeManipulability } from './jacobian.js'
import { sub, norm, normalize, scale } from '../math/vector.js'
import { clampScalar } from '../math/vector.js'
import {
  mat3_inverse, mat3_add_scaled_identity,
  matMN_multiply, matMN_transpose, matMN_vec_multiply
} from '../math/matrix.js'

const BASE_LAMBDA = 0.5
const MAX_DELTA_Q = 0.05
const MAX_ERROR = 0.5

export function solveIK(state, target, iterations = 5)
  // Mutates state.angles in place
  //
  // for iter = 0 to iterations - 1:
  //   fk = forwardKinematics(state)
  //   ee = fk.positions[state.numJoints]
  //   error = sub(target, ee)
  //
  //   // Early exit
  //   if norm(error) < 0.001: break
  //
  //   // Clamp error vector magnitude
  //   if norm(error) > MAX_ERROR:
  //     error = scale(normalize(error), MAX_ERROR)
  //
  //   J = computeJacobian(fk.positions, fk.axes, state.numJoints)
  //
  //   // Adaptive damping
  //   w = computeManipulability(J, state.numJoints)
  //   lambda = BASE_LAMBDA + (w < 0.01 ? 0.5 / (w + 0.001) : 0)
  //   lambda = Math.min(lambda, 5.0)
  //
  //   // Pseudoinverse: J_pinv = Jt * inv(J * Jt + lambda^2 * I)
  //   Jt = matMN_transpose(J, 3, N)                         // Nx3
  //   JJt = matMN_multiply(J, Jt, 3, N, 3)                  // 3x3
  //   JJt_damped = mat3_add_scaled_identity(JJt, lambda * lambda)  // 3x3
  //   JJt_inv = mat3_inverse(JJt_damped)                     // 3x3
  //   J_pinv = matMN_multiply(Jt, JJt_inv, N, 3, 3)         // Nx3
  //
  //   // delta_q = J_pinv * error
  //   delta_q = matMN_vec_multiply(J_pinv, error, N, 3)      // length N
  //
  //   // Clamp per joint
  //   for i in 0..N-1:
  //     delta_q[i] = clampScalar(delta_q[i], -MAX_DELTA_Q, MAX_DELTA_Q)
  //
  //   // Apply
  //   for i in 0..N-1:
  //     state.angles[i] += delta_q[i]

export function computePseudoinverse(J, numJoints, lambda)
  // Same pseudoinverse logic as above, extracted for reuse by nullspace.js
  // Returns J_pinv as Float64Array(numJoints * 3) -- Nx3 matrix
```

