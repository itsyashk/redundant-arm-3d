### src/kinematics/nullspace.js
Null space projection and secondary objective.

```
import { forwardKinematics } from './fk.js'
import { computeJacobian } from './jacobian.js'
import { computePseudoinverse, solveIK } from './ik.js'
import { distance } from '../math/vector.js'
import { clampScalar } from '../math/vector.js'
import { matMN_multiply, matN_identity, matMN_subtract, matMN_vec_multiply } from '../math/matrix.js'

const NULLSPACE_GAIN = 0.1
const MAX_NULL_DELTA = 0.03
const DRIFT_THRESHOLD = 0.002

export function applyNullSpace(state, sliderValue)
  // Does nothing if abs(sliderValue) < 0.001 or numJoints <= 3
  //
  // 1. Compute FK, Jacobian, Pseudoinverse
  //    fk = forwardKinematics(state)
  //    ee_before = [...fk.positions[state.numJoints]]  // COPY, not reference
  //    J = computeJacobian(...)
  //    J_pinv = computePseudoinverse(J, N, lambda=0.5)
  //
  // 2. Secondary objective: bias toward zero config
  //    z = new Array(N)
  //    for i = 0..N-1: z[i] = -sliderValue * NULLSPACE_GAIN * state.angles[i]
  //
  // 3. Null space projector: N_proj = I_NxN - J_pinv * J
  //    JpJ = matMN_multiply(J_pinv, J, N, 3, N)     // NxN
  //    I_N = matN_identity(N)                          // NxN
  //    N_proj = matMN_subtract(I_N, JpJ, N*N)          // NxN
  //
  // 4. Project: dq = N_proj * z
  //    dq = matMN_vec_multiply(N_proj, z, N, N)
  //
  // 5. Clamp
  //    for i: dq[i] = clampScalar(dq[i], -MAX_NULL_DELTA, MAX_NULL_DELTA)
  //
  // 6. Apply
  //    for i: state.angles[i] += dq[i]
  //
  // 7. DRIFT CORRECTION (critical)
  //    fk_after = forwardKinematics(state)
  //    ee_after = fk_after.positions[state.numJoints]
  //    if distance(ee_before, ee_after) > DRIFT_THRESHOLD:
  //      solveIK(state, ee_before, 3)  // snap back to original ee position
```

