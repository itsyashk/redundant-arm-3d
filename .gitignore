### src/scene/setup.js
Three.js scene initialization. Exports the scene objects other modules need.

```
import * as THREE from 'three'
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js'

export function createScene(container)
  // container is the DOM element to mount the renderer in
  //
  // Creates and returns:
  // {
  //   scene,
  //   camera,
  //   renderer,
  //   controls,    // OrbitControls instance
  // }
  //
  // Renderer:
  //   antialias: true
  //   setPixelRatio(window.devicePixelRatio)
  //   shadowMap.enabled = true
  //   shadowMap.type = THREE.PCFSoftShadowMap
  //   toneMapping = THREE.ACESFilmicToneMapping
  //   toneMappingExposure = 1.2
  //   Size: fills the container element (not full window — sidebar takes space)
  //
  // Scene:
  //   background = new THREE.Color(0x0a0a1a)
  //   fog = new THREE.FogExp2(0x0a0a1a, 0.06)
  //
  // Camera:
  //   PerspectiveCamera(50, aspect, 0.1, 100)
  //   position.set(4, 3, 4)
  //
  // Lighting:
  //   AmbientLight(0x404060, 0.6)
  //   DirectionalLight(0xffffff, 1.0) at (5, 8, 5) with shadow
  //   DirectionalLight(0x8888ff, 0.3) at (-3, 2, -3) fill
  //   HemisphereLight(0x606080, 0x202040, 0.5)
  //
  // OrbitControls:
  //   target.set(0, 1.4, 0)
  //   enableDamping = true
  //   dampingFactor = 0.08
  //   minDistance = 1.5
  //   maxDistance = 12
  //   maxPolarAngle = Math.PI * 0.85
  //
  // Resize handler:
  //   Listen on window resize
  //   Update camera aspect based on container size (NOT window.innerWidth)
  //   Update renderer size to container size
```

