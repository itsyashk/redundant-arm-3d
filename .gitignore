### src/interaction/drag.js
3D drag interaction system. This is the most fragile module — follow spec exactly.

```
import * as THREE from 'three'

export function createDragSystem(camera, renderer, controls, getEEMesh, onDragStart, onDrag, onDragEnd)
  // getEEMesh: function that returns the current end effector mesh (needed because it changes on rebuild)
  // onDragStart: callback()
  // onDrag: callback(targetPosition: [x,y,z])
  // onDragEnd: callback()
  //
  // Internal state:
  //   isDragging = false
  //   dragPlane = new THREE.Plane()
  //   raycaster = new THREE.Raycaster()
  //   mouse = new THREE.Vector2()
  //   intersection = new THREE.Vector3()
  //
  // Target indicator:
  //   Small sphere (radius 0.05, MeshBasicMaterial, color 0xffaa00, transparent, opacity 0.6)
  //   Starts visible = false
  //   Added to scene
  //   Shows where the user is dragging to
  //
  // --- EVENT: pointerdown on renderer.domElement ---
  //   1. Compute mouse NDC from event.clientX, event.clientY
  //      IMPORTANT: account for canvas offset, not just window size
  //      const rect = renderer.domElement.getBoundingClientRect()
  //      mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1
  //      mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1
  //
  //   2. raycaster.setFromCamera(mouse, camera)
  //
  //   3. intersects = raycaster.intersectObject(getEEMesh())
  //      Also test a slightly larger invisible sphere around ee for easier grabbing:
  //      Use raycaster threshold or create a larger invisible mesh for hit testing
  //
  //   4. If hit:
  //      isDragging = true
  //      controls.enabled = false
  //      const camDir = new THREE.Vector3()
  //      camera.getWorldDirection(camDir)
  //      const eePos = getEEMesh().position.clone()
  //      dragPlane.setFromNormalAndCoplanarPoint(camDir, eePos)
  //      onDragStart()
  //      event.preventDefault()
  //      event.stopPropagation()
  //
  // --- EVENT: pointermove on renderer.domElement ---
  //   If not isDragging: return
  //   Update mouse NDC (same rect calculation)
  //   raycaster.setFromCamera(mouse, camera)
  //   if raycaster.ray.intersectPlane(dragPlane, intersection):
  //     // Sanity check: don't let target go too far from ee
  //     if intersection.distanceTo(getEEMesh().position) < 5:
  //       targetIndicator.position.copy(intersection)
  //       targetIndicator.visible = true
  //       onDrag([intersection.x, intersection.y, intersection.z])
  //   event.preventDefault()
  //
  // --- EVENT: pointerup on window (NOT just canvas — catches drags that leave the canvas) ---
  //   if isDragging:
  //     isDragging = false
  //     controls.enabled = true
  //     targetIndicator.visible = false
  //     onDragEnd()
  //
  // Returns: {
  //   isDragging(): boolean getter
  //   dispose(): removes all event listeners
  //   targetMesh: the target indicator mesh (add to scene externally)
  // }
```

